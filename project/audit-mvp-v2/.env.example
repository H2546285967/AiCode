# ===== Server =====
PORT=3000
NODE_ENV=development

# ===== Storage =====
DB_PATH=./data/audit.db
UPLOAD_DIR=./uploads

# ===== AI Provider (Kimi · OpenAI 兼容协议) =====
# 面试演示时填入 Kimi API Key，留空则走 Mock 模式
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k-vision-preview

# ===== Feature Flag =====
# true = 用 Mock 数据（不消耗 API 配额，演示也能跑）
# false = 调用真实 Kimi API
USE_MOCK=true